# ============================================================
# Vox Local Story TTS - example config
# Copy file này thành .env rồi sửa theo máy của bạn.
# ============================================================

# ------------------------------------------------------------
# 1) Bảo mật API
# ------------------------------------------------------------
# Cách đơn giản nhất: một key chung cho tất cả client.
# Nên đổi giá trị này trước khi cho máy khác trong LAN truy cập.
LOCAL_API_KEY=

# Cách tốt hơn khi nhiều người dùng chung server:
# mỗi người hoặc mỗi extension có một key riêng.
# Format: ten_nguoi:key,ten_khac:key_khac
LOCAL_API_KEYS=

# Cách bảo mật hơn nữa: chỉ lưu SHA-256 hash của key trong .env.
# Dùng .\vox.bat key -Label ten_nguoi để sinh.
# Format: ten_nguoi:sha256hex,ten_khac:sha256hex
LOCAL_API_KEY_HASHES=

# ------------------------------------------------------------
# 1b) Web UI auth
# ------------------------------------------------------------
# false: mở web UI không cần login.
# true: truy cập / và /api sẽ bị chuyển sang /login nếu chưa có session.
WEB_AUTH_ENABLED=false

# api_key: đăng nhập UI bằng API key ở trên.
# google: đăng nhập UI bằng Google OAuth.
# Có thể dùng cả hai: api_key,google
WEB_AUTH_PROVIDERS=api_key

# Khuyến nghị sinh chuỗi dài ngẫu nhiên riêng cho cookie session.
# Nếu để trống, server tự sinh secret khi khởi động; restart sẽ làm logout tất cả session.
WEB_SESSION_SECRET=
WEB_SESSION_HOURS=24

# Chỉ bật true nếu server chạy qua HTTPS.
WEB_AUTH_COOKIE_SECURE=false

# ------------------------------------------------------------
# 1c) Google OAuth cho Web UI, tùy chọn
# ------------------------------------------------------------
# Cần tạo OAuth Client dạng Web application trong Google Cloud Console.
# Redirect URI phải khớp chính xác URL server của bạn.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8010/auth/google/callback

# Bắt buộc nên có allowlist. Nếu Google OAuth bật mà không có allowlist,
# server sẽ coi Google chưa cấu hình đủ.
GOOGLE_ALLOWED_EMAILS=
GOOGLE_ALLOWED_DOMAINS=

# ------------------------------------------------------------
# 2) Provider TTS
# ------------------------------------------------------------
# capcut: dùng K07VN/capcut-tts-api để có voice CapCut, gồm Cô Gái Hoạt Ngôn.
# auto: ưu tiên CapCut nếu cấu hình đúng, fallback local nếu bật.
# local: chỉ dùng Windows Speech API offline, không phải giọng CapCut.
TTS_PROVIDER=capcut
ALLOW_NETWORK_TTS=true
TTS_FALLBACK_TO_LOCAL=false

# ------------------------------------------------------------
# 3) CapCut provider
# ------------------------------------------------------------
# Nếu chạy .\vox.bat setup hoặc .\vox.bat setup-capcut, CLI sẽ clone provider vào providers/capcut-tts-api.
CAPCUT_CLIENT_PATH=providers/capcut-tts-api/capcut_common_task_client.py
CAPCUT_PYTHON=python
# Để trống nếu chưa có file device riêng.
# Nếu bạn có device JSON hợp lệ, đặt ví dụ: CAPCUT_DEVICE_JSON=capcut_device_windows.json
CAPCUT_DEVICE_JSON=capcut_device_windows.json

# ------------------------------------------------------------
# 4) Windows offline fallback
# ------------------------------------------------------------
LOCAL_TTS_VOICE=
LOCAL_TTS_DISPLAY_NAME=Giọng đọc Windows offline
LOCAL_TTS_POWERSHELL=pwsh
LOCAL_TTS_VOLUME=100

# ------------------------------------------------------------
# 5) Cache và giới hạn TTS
# ------------------------------------------------------------
CACHE_DIR=./audio_cache
MAX_TEXT_LENGTH=3800
TTS_TIMEOUT_SECONDS=180
TTS_POLL_SECONDS=2

# ------------------------------------------------------------
# 6) Network
# ------------------------------------------------------------
# Local only, an toàn nhất:
HOST=127.0.0.1

# Muốn máy khác trong LAN truy cập thì đổi thành:
# HOST=0.0.0.0
PORT=8010

